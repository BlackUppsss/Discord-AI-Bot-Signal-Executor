# Discord Configuration
# Masukkan token akun Discord Anda dan ID Channel yang ingin dipantau
# Jika ingin banyak channel, pisahkan dengan koma: 1234,5678,91011
DISCORD_USER_TOKEN=your_discord_user_token_here
TARGET_CHANNEL_IDS=your_target_channel_id_here

# KEAMANAN: Hanya terima sinyal dari user ID ini (pisahkan dengan koma)
# Dapatkan user ID dengan mengaktifkan Developer Mode di Discord → Klik kanan user → Copy User ID
# Kosongkan jika ingin menerima dari siapa saja (TIDAK DISARANKAN untuk akun Live!)
TRUSTED_AUTHOR_IDS=

# Anti-spam: Jeda minimum antar pesan yang diproses (detik, default: 3)
MESSAGE_COOLDOWN_SEC=0

# Agentic / AI Configuration
# Masukkan API Key Google Gemini Anda (Dapatkan di Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Bitget API (Pilih Live atau Demo/Testnet) ---
# Masukkan API Key yang Anda buat di pengaturan Bitget Anda
BITGET_API_KEY=your_bitget_api_key_here
BITGET_API_SECRET=your_bitget_api_secret_here
BITGET_PASSPHRASE=your_bitget_passphrase_here

# --- Risk Management ---
# Berapa % dari total saldo yang direlakan hilang jika trade terkena Stop Loss (Default: 5)
RISK_PERCENTAGE=5

# Maks % equity yang boleh dipakai untuk satu posisi (Default: 50)
MAX_POSITION_PCT=50

# Minimum order dalam USDT (Default: 5)
MIN_ORDER_USDT=5

# Leverage bawaan jika sinyal di Discord tidak menyebutkan leverage (Default: 20x)
DEFAULT_LEVERAGE=20

# --- Monitor / Break-Even Manager (monitor.py) ---
# Pindahkan SL ke Break Even saat posisi sudah mencapai RR ini (default: 0.80)
BE_RR_TRIGGER=0.80
# Refresh daftar posisi aktif dari Bitget setiap N detik (default: 30)
POSITION_POLL_SEC=30
# Set ke "true" untuk mode Demo/Sandbox, "false" untuk akun Live
BITGET_SANDBOX=true

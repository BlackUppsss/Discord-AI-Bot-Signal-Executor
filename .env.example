# Discord Configuration
# Masukkan token akun Discord Anda dan ID Channel yang ingin dipantau
DISCORD_USER_TOKEN=your_discord_user_token_here
TARGET_CHANNEL_ID=your_target_channel_id_here

# Agentic / AI Configuration
# Masukkan API Key Google Gemini Anda (Dapatkan di Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Bitget API (Pilih Live atau Demo/Testnet) ---
# Masukkan API Key yang Anda buat di pengaturan Bitget Anda
BITGET_API_KEY=your_bitget_api_key_here
BITGET_API_SECRET=your_bitget_api_secret_here
BITGET_PASSPHRASE=your_bitget_passphrase_here

# --- Risk Management ---
# Berapa % dari total saldo yang direlakan hilang jika trade terkena Stop Loss (Default: 5)
RISK_PERCENTAGE=5

# Leverage bawaan jika sinyal di Discord tidak menyebutkan leverage (Default: 20x)
DEFAULT_LEVERAGE=20
